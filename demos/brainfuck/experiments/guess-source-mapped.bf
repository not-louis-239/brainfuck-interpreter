[
    Source-mapped BF file for a number-guessing game

    Original code:

------------------------------------------------------
/*  Number guessing game in Crimscript  */

print("I'm thinking of a number from 1 to 9.\n")
input("Enter your guess: ")
// Pointer is now at INPUT (0)

// Set success flag initial value (1 right of stdin)
>+<; -51

until 0 {
    // If we're here, the number was not '3' (ASCII 51)

    // Set failure flag 2 right of stdin
    >2; +;

    // Kill the success flag
    <1; clear()

    // Now destroy the input
    <1; clear()
}

// Success branch
>1
until 0 {
    // If we're here, the number was right

    <; print("Correct!")

    // Now destroy the success flag to exit the loop
    >; clear()
}
<1

// Failure branch
>2
until 0 {
    // If we're here, the number was wrong.
    <2; print("You failed!")

    >2; clear()
}
<2


// end with a newline
print("\n")
------------------------------------------------------
]

