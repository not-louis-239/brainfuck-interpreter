#!/usr/bin/env python3

import sys
from pathlib import Path
from dataclasses import dataclass

sys.path.insert(0, str(Path(__file__).parents[1] / "src"))

from brainfuck.cmdb.data_manager import load_debug
from brainfuck.compiler.get_line_and_col import get_line_and_col
from brainfuck.interpreter.run_brainfuck import run_brainfuck
from brainfuck.interpreter.exceptions import BrainfuckException
from brainfuck.interpreter.format_traceback import format_bf_traceback
from brainfuck.utils.format_tools import COL_BOLD, COL_ERR, COL_ERR_HIGHLIGHT, COL_RESET

ASCII_SPECIAL_CASES: dict[int, str] = {
    0: "NUL",
    1: "SOH",
    2: "STX",
    3: "ETX",
    4: "EOT",
    5: "ENQ",
    6: "ACK",
    7: "BEL",
    8: "BS",
    9: "TAB",
    10: "LF",
    11: "VT",
    12: "FF",
    13: "CR",
    14: "SO",
    15: "SI",
    16: "DLE",
    17: "DC1",
    18: "DC2",
    19: "DC3",
    20: "DC4",
    21: "NAK",
    22: "SYN",
    23: "ETB",
    24: "CAN",
    25: "EM",
    26: "SUB",
    27: "ESC",
    28: "FS",
    29: "GS",
    30: "RS",
    31: "US",
    127: "DEL",
}

def fatal_err(msg: str) -> None:
    print(f"{Path(__file__).name}: fatal: {msg}")
    sys.exit(1)

@dataclass
class Args:
    bf_path: Path
    debug_path: Path

def parse_args() -> Args:
    args_raw = sys.argv[1:]

    if not args_raw:
        fatal_err("missing arguments. run with -h or --help for usage information")
    if "-h" in args_raw or "--help" in args_raw:
        print(f"usage: {Path(__file__).name} bf_path [-d debug_path]")
        sys.exit(0)

    # Parse positional and optional args
    exec_path = args_raw[0]
    debug_path = None

    if len(args_raw) > 1:
        if args_raw[1] != "-d":
            fatal_err(f"unknown argument: {args_raw[1]}")
        if len(args_raw) < 3:
            fatal_err("missing debug path after -d")
        debug_path = args_raw[2]

    # Validate exec file
    exec_file = Path(exec_path)
    if not exec_file.exists():
        fatal_err(f"no such file: {exec_path}")
    if not exec_file.is_file():
        fatal_err(f"invalid file: {exec_path}")

    # --- resolve debug path ---
    if debug_path is None:
        debug_file = exec_file.with_suffix(exec_file.suffix + ".debug.json")
        print(f"debug path not provided. assuming debug file is '{debug_file}'")
    else:
        debug_file = Path(debug_path)
        if not debug_file.exists():
            fatal_err(f"specified debug path doesn't exist: {debug_path}")
        if not debug_file.is_file():
            fatal_err(f"invalid debug file: {debug_path}")

    return Args(
        bf_path=exec_file,
        debug_path=debug_file,
    )

def main() -> None:
    args = parse_args()
    debug_info = load_debug(args.debug_path)

    with open(args.bf_path, "r") as f:
        bf_code = f.read().splitlines()

    try:
        run_brainfuck(src_code=bf_code)
    except BrainfuckException as e:
        # Print the standard traceback
        print(format_bf_traceback(e))

        # Now print the Crimscript trace
        print("\nCrimscript trace:")

        bf_ip = e.position
        cms_ip = debug_info.get_crim_instruction(bf_ip)
        line, col = get_line_and_col(debug_info.src_code, cms_ip)
        print(f"{COL_BOLD}at {args.debug_path}:{line}:{col}{COL_RESET}")
        print(f"{COL_ERR_HIGHLIGHT}{debug_info.src_code[line-1]}{COL_RESET}")
        print(f"{COL_ERR}^{' ' * (col-1)}{COL_RESET}")

        # Memory trace
        if e.mem is not None:
            print("\nMemory trace at error:")
            print("Addr    Dec  Hex  Chr")

            # Get the max memory address whose value is != 0
            max_ptr = max(ptr for ptr, val in enumerate(e.mem) if val != 0)
            ptr = 0
            while ptr <= max_ptr:
                val = e.mem[ptr]

                if val == 0:
                    # Collapse long runs of zero memory into a single summary line.
                    run_start = ptr
                    while ptr <= max_ptr and e.mem[ptr] == 0:
                        ptr += 1
                    run_length = ptr - run_start

                    if run_length >= 3:
                        print("  ...")
                        continue

                    # Print short zero runs explicitly
                    for explicit_ptr in range(run_start, ptr):
                        explicit_val = 0
                        chr_repr = ASCII_SPECIAL_CASES.get(explicit_val, chr(explicit_val) if 32 <= explicit_val < 127 else "?")
                        print(f"  [{explicit_ptr}]: {explicit_val:3d} {explicit_val:02X} {chr_repr}")
                    continue

                chr_repr = ASCII_SPECIAL_CASES.get(val, chr(val) if 32 <= val < 127 else "?")
                print(f"  [{ptr}]: {val:3d} {val:02X} {chr_repr}")
                ptr += 1
        else:
            print("\nNo memory trace available at error.")

        sys.exit(1)

if __name__ == "__main__":
    main()
