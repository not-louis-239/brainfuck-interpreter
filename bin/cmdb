#!/usr/bin/env python3

import sys
from pathlib import Path
from dataclasses import dataclass

sys.path.insert(0, str(Path(__file__).parents[1] / "src"))

from brainfuck.compiler.debug_info import DebugInfo
from brainfuck.cmdb.data_manager import load_debug
from brainfuck.compiler.get_line_and_col import get_line_and_col
from brainfuck.interpreter.run_brainfuck import run_brainfuck
from brainfuck.interpreter.exceptions import BrainfuckException
from brainfuck.interpreter.format_traceback import format_bf_traceback
from brainfuck.utils.format_tools import COL_BOLD, COL_ERR, COL_ERR_HIGHLIGHT, COL_RESET

ASCII_SPECIAL_CASES: dict[int, str] = {
    0: "NUL",
    1: "SOH",
    2: "STX",
    3: "ETX",
    4: "EOT",
    5: "ENQ",
    6: "ACK",
    7: "BEL",
    8: "BS",
    9: "TAB",
    10: "LF",
    11: "VT",
    12: "FF",
    13: "CR",
    14: "SO",
    15: "SI",
    16: "DLE",
    17: "DC1",
    18: "DC2",
    19: "DC3",
    20: "DC4",
    21: "NAK",
    22: "SYN",
    23: "ETB",
    24: "CAN",
    25: "EM",
    26: "SUB",
    27: "ESC",
    28: "FS",
    29: "GS",
    30: "RS",
    31: "US",
    127: "DEL",
}

def fatal_err(msg: str) -> None:
    print(f"{Path(__file__).name}: fatal: {msg}")
    sys.exit(1)

@dataclass
class Args:
    bf_path: Path
    debug_path: Path

def parse_args() -> Args:
    args_raw = sys.argv[1:]

    if not args_raw:
        fatal_err("missing arguments. run with -h or --help for usage information")
    if "-h" in args_raw or "--help" in args_raw:
        print(f"usage: {Path(__file__).name} bf_path [-d debug_path]")
        sys.exit(0)

    # Parse positional and optional args
    exec_path = args_raw[0]
    debug_path = None

    if len(args_raw) > 1:
        if args_raw[1] != "-d":
            fatal_err(f"unknown argument: {args_raw[1]}")
        if len(args_raw) < 3:
            fatal_err("missing debug path after -d")
        debug_path = args_raw[2]

    # Validate exec file
    exec_file = Path(exec_path)
    if not exec_file.exists():
        fatal_err(f"no such file: {exec_path}")
    if not exec_file.is_file():
        fatal_err(f"invalid file: {exec_path}")

    # --- resolve debug path ---
    if debug_path is None:
        debug_file = exec_file.with_suffix(exec_file.suffix + ".debug.json")
        print(f"debug path not provided. assuming debug file is '{debug_file}'")
    else:
        debug_file = Path(debug_path)
        if not debug_file.exists():
            fatal_err(f"specified debug path doesn't exist: {debug_path}")
        if not debug_file.is_file():
            fatal_err(f"invalid debug file: {debug_path}")

    return Args(
        bf_path=exec_file,
        debug_path=debug_file,
    )

def _get_mem_line(ptr: int, val: int) -> str:
    ptr_str = f"{ptr:05d}"
    val_b10_str = f"{val:03d}"
    val_b16_str = f"{val:02X}"
    if val in ASCII_SPECIAL_CASES:
        chr_repr = ASCII_SPECIAL_CASES[val]
    elif 32 <= val < 127:
        chr_repr = chr(val)
    else:
        chr_repr = f"\\x{val:02X}"

    # Address colour is yellow for in-bounds, red for out-of-bounds (assuming 30,000 cell memory)
    # Value colour is colourless for in-bounds, red for addresses that are OOB
    if 0 <= ptr < 30_000:
        mem_col = "\033[33m"  # yellow
        val_col = ""  # none
    else:
        mem_col = "\033[31m"  # red
        val_col = "\033[31m"  # red

    return f"[{mem_col}{ptr_str}\033[0m]   {val_col}{val_b10_str}  {val_b16_str}   {chr_repr}{COL_RESET}"

def print_crimscript_trace(e: BrainfuckException, debug_info: DebugInfo, args: Args) -> None:
    print("\nCrimscript trace:")
    bf_ip = e.position
    cms_ip = debug_info.get_crim_instruction(bf_ip)
    line, col = get_line_and_col(debug_info.src_code, cms_ip)
    print(f"  at \033[31m{debug_info.src_crim_path}:{line}:{col}{COL_RESET}:\n")
    print(f"{COL_ERR_HIGHLIGHT}{debug_info.src_code[line-1]}{COL_RESET}")
    print(f"{COL_ERR_HIGHLIGHT}{' ' * (col-1)}^{COL_RESET}")

def print_memory_trace(e: BrainfuckException) -> None:
    if e.ptr is not None:
        print("\nMemory trace at error:")
        print("Addr      Dec  Hex  Chr")
        print("--------------------------")

        display_offset_range = 20  # how many cells to show on either side of the pointer

        # Need to show the first out-of-bounds cell in either direction to make it clear
        # when the error is due to OOB access
        start_offset = max(-1, e.ptr - display_offset_range)
        end_offset = min(30_000, e.ptr + display_offset_range)

        # Print cells from (-20..+20) around the pointer, with the pointer cell highlighted
        for ptr in range(start_offset, end_offset + 1):
            val = e.mem[ptr] if e.mem is not None and 0 <= ptr < len(e.mem) else 0
            line = _get_mem_line(ptr, val)
            if ptr == e.ptr:
                print(f"{line}{COL_RESET} {COL_ERR_HIGHLIGHT}<-- pointer{COL_RESET}")
            else:
                print(line)
    else:
        print("\nMemory trace unavailable (pointer position unavailable).")

def main() -> None:
    args = parse_args()
    debug_info = load_debug(args.debug_path)

    with open(args.bf_path, "r") as f:
        bf_code = f.read().splitlines()

    try:
        run_brainfuck(src_code=bf_code)
    except BrainfuckException as e:
        # Print the standard traceback
        print(format_bf_traceback(e))

        # Now print the Crimscript trace (ONLY if debug info is available, otherwise just print the BF traceback)
        if debug_info is not None:
            print_crimscript_trace(e, debug_info, args)
        else:
            print("\nCrimscript trace unavailable (no debug info).")

        # Memory trace
        if e.mem is not None:
            print_memory_trace(e)
        else:
            print("\nNo memory trace available at error.")

        sys.exit(1)

if __name__ == "__main__":
    main()
