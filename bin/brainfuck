#!/usr/bin/env python3

import sys
from dataclasses import dataclass
from pathlib import Path
from typing import NoReturn

sys.path.insert(0, str(Path(__file__).parents[1] / "src"))

from brainfuck.interpreter.run_brainfuck import BrainfuckInterpreter
from brainfuck.interpreter.exceptions import BrainfuckException, BFInterrupt
from brainfuck.interpreter.format_traceback import format_bf_traceback
from brainfuck.interpreter.show_ascii import show_ascii

@dataclass
class Args:
    path: str
    wrap: bool
    memsize: int

def fatal_err(message: str) -> NoReturn:
    print(f"{Path(__file__).name}: fatal: {message}", file=sys.stderr)
    sys.exit(1)

def parse_args() -> Args:
    argv = sys.argv

    if len(argv) < 2:
        fatal_err("missing args. run with -h or --help for usage information")
        sys.exit(1)

    if argv[1] in ("-h", "--help"):
        # Do NOT print to stderr here since this is not an error case
        print(f"usage: {Path(__file__).name} <file> [-w, --wrap] [-m, --memsize N]")
        print("ASCII Guide")
        show_ascii()

        sys.exit(0)

    path = argv[1]
    wrap = False
    memsize = 30_000

    i = 2
    while i < len(argv):
        arg = argv[i]

        if arg in ("-w", "--wrap"):
            wrap = True

        elif arg in ("-m", "--memsize"):
            i += 1
            if i >= len(argv):
                fatal_err("brainfuck: error: (-m, --memsize) requires a >0 integer value")

            try:
                memsize = int(argv[i])
                if memsize <= 0:
                    fatal_err(f"brainfuck: invalid memsize value: '{argv[i]}' (must be int and >0)")
            except ValueError:
                fatal_err(f"brainfuck: invalid memsize value: '{argv[i]}' (must be int and >0)")

        else:
            fatal_err(f"brainfuck: unknown arg: {arg}")

        i += 1

    return Args(path=path, wrap=wrap, memsize=memsize)

def main():
    args = parse_args()

    # Attempt to parse the file
    try:
        with open(args.path, 'r', encoding="utf-8") as f:
            src_code = f.read().splitlines()
    except IsADirectoryError:
        fatal_err(f"'{args.path}' is a directory")
    except FileNotFoundError:
        fatal_err(f"no such file or directory: {args.path}")

    # Spawn the interpreter
    bfi = BrainfuckInterpreter()

    # Run Brainfuck and handle runtime exceptions
    try:
        bfi.run_brainfuck(src_code=src_code, wrap=args.wrap, memsize=args.memsize)
    except BrainfuckException as e:
        print(format_bf_traceback(e), file=sys.stderr)
        sys.exit(1)
    except KeyboardInterrupt:
        exc = BFInterrupt(message="program interrupted by user", position=bfi.ist, src_code=src_code)
        print(format_bf_traceback(exc), file=sys.stderr)
        sys.exit(130)

if __name__ == "__main__":
    main()
