#!/usr/bin/env python3

import sys
from dataclasses import dataclass
from pathlib import Path
from typing import NoReturn

sys.path.insert(0, str(Path(__file__).parents[1] / "src"))

from brainfuck.compiler.compile_crimscript import CrimscriptDriver
from brainfuck.compiler.exceptions import CompilerException
from brainfuck.compiler.format_errors import format_err
from brainfuck.cmdb.data_manager import save_debug

@dataclass
class Args:
    input_path: str
    output_path: str
    danger_allow_clobber: bool = False
    debug_symbols: bool = False

def fatal_err(message: str) -> NoReturn:
    print(f"{Path(__file__).name}: fatal: {message}", file=sys.stderr)
    sys.exit(1)

def parse_args() -> Args:
    DEBUG_ARGS: tuple[str, ...] = ("--debug", "-d")
    ALLOW_CLOBBER_ARGS: tuple[str, ...] = ("--allow-clobber", "-f")

    args = sys.argv[1:]

    if not args:
        fatal_err("missing args. run with -h or --help for usage information")

    if args[0] in ("-h", "--help"):
        print(f"usage: {sys.argv[0]} <input_path> [output_path] [-f, --allow-clobber] [{" ".join(DEBUG_ARGS)}]")
        print(f"  input_path            path to the input Crimscript file to compile")
        print(f"  output_path           path to write the output Brainfuck file")
        print(f"  -f, --allow-clobber   allow overwriting the output file if it already exists")
        sys.exit(0)

    danger_allow_clobber = False
    debug_symbols_enabled = False

    # Check for --allow-clobber flag and remove it from args if present
    if (a in args for a in ALLOW_CLOBBER_ARGS):
        print("WARNING: (-f, --allow-clobber) is enabled. This will overwrite the output file if it exists.")
        danger_allow_clobber = True
        args = [a for a in args if a not in ALLOW_CLOBBER_ARGS]

    # Check for --debug flag and remove it from args if present
    if any(d in args for d in DEBUG_ARGS):
        print("(-d, --debug) flag enabled. The compiler will add debug symbols to the output Brainfuck code.")
        debug_symbols_enabled = True
        args = [a for a in args if a not in DEBUG_ARGS]

    if len(args) != 2:
        fatal_err("invalid number of arguments. run with -h for usage information")

    input_path = args[0]
    if not Path(input_path).exists():
        fatal_err(f"cannot read from input: no such file: {input_path}")
    if not Path(input_path).is_file():
        fatal_err(f"invalid file: {input_path}")

    output_path = args[1]
    if Path(output_path).exists():
        if danger_allow_clobber:
            print(f"WARNING: Overwriting existing file '{output_path}'")
        else:
            fatal_err(
                f"output file '{output_path}' already exists. "
                f"(run with --allow-clobber to overwrite)"
            )

    return Args(
        input_path=input_path,
        output_path=output_path,
        danger_allow_clobber=danger_allow_clobber,
        debug_symbols=debug_symbols_enabled
    )

def main():
    # Compile some Crimscript code in a file and output it to another file
    # NO CLOBBERING: Do NOT overwrite the output file if it exists.
    # If no output file is given, print the output to stdout.

    args = parse_args()
    compiler = CrimscriptDriver()

    try:
        with open(args.input_path, "r") as file:
            code = file.read().splitlines()
        compiler_output = compiler.compile_crimscript(code, debug_symbols=args.debug_symbols)

        with open(args.output_path, "w") as file:
            file.write(compiler_output.bf_code)
        if compiler_output.debug is not None:
            # TODO: add handling to avoid overwriting debug files if -f is not enabled
            save_debug(debug=compiler_output.debug, bf_path=Path(args.output_path), src_crim_path=Path(args.input_path))
    except IsADirectoryError:
        fatal_err(f"'{args.input_path}' is a directory")
    except FileNotFoundError:
        fatal_err(f"no such file or directory: {args.input_path}")
    except CompilerException as e:
        print(format_err(e), file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
